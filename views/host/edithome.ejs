<%- include('../partials/head') %>

    <body class="bg-gray-900 min-h-screen flex flex-col">

        <%- include('../partials/nav') %>

            <!-- Form Container -->
            <div class="flex justify-center items-center flex-grow mt-10">

                <form action="/host/<%= editing ? 'edit-home' : 'add-home' %>" method="POST"
                    enctype="multipart/form-data" class="w-full max-w-xl
                    mx-auto
                    bg-white/10
                    backdrop-blur-2xl
                    border border-white/20
                    rounded-[30px]
                    shadow-[0_20px_60px_rgba(0,0,0,0.45)]
                    p-10
                    space-y-6">

                    <h2 class="text-4xl font-bold text-center text-white">
                        <%= editing ? 'Edit Your Home' : 'Add Your Home' %>
                    </h2>

                    <p class="text-center text-gray-300">
                        Share your property with travelers around the world.
                    </p>

                    <input type="hidden" name="id" value="<%= home ? home._id : '' %>">

                    <!-- House Name -->

                    <input type="text" name="houseName" placeholder="House Name"
                        value="<%= home ? home.houseName : '' %>" class="w-full
                        px-5 py-3
                        rounded-xl
                        bg-white/10
                        border border-white/20
                        text-white
                        placeholder-gray-400
                        focus:outline-none
                        focus:ring-2
                        focus:ring-red-400">

                    <!-- Price -->

                    <input type="text" name="price" placeholder="Price per Night" value="<%= home ? home.price : '' %>"
                        class="w-full
                        px-5 py-3
                        rounded-xl
                        bg-white/10
                        border border-white/20
                        text-white
                        placeholder-gray-400
                        focus:outline-none
                        focus:ring-2
                        focus:ring-red-400">

                    <!-- Location -->

                    <input type="text" name="location" placeholder="Location" value="<%= home ? home.location : '' %>"
                        class="w-full
                        px-5 py-3
                        rounded-xl
                        bg-white/10
                        border border-white/20
                        text-white
                        placeholder-gray-400
                        focus:outline-none
                        focus:ring-2
                        focus:ring-red-400">

                    <!-- Rating -->

                    <input type="text" name="rating" placeholder="Rating" value="<%= home ? home.rating : '' %>" class="w-full
                        px-5 py-3
                        rounded-xl
                        bg-white/10
                        border border-white/20
                        text-white
                        placeholder-gray-400
                        focus:outline-none
                        focus:ring-2
                        focus:ring-red-400">

                    <!-- Image -->

                    <input type="file" name="photo" class="w-full
                        px-5 py-3
                        rounded-xl
                        bg-white/10
                        border border-white/20
                        text-gray-300
                        file:bg-red-500
                        file:text-white
                        file:border-0
                        file:px-4
                        file:py-2
                        file:rounded-lg
                        file:mr-4
                        cursor-pointer">

                    <!-- Description -->

                    <textarea name="description" rows="5" placeholder="Describe your home..." class="w-full
                        px-5 py-3
                        rounded-xl
                        bg-white/10
                        border border-white/20
                        text-white
                        placeholder-gray-400
                        resize-none
                        focus:outline-none
                        focus:ring-2
                        focus:ring-red-400"><%= home ? home.description : '' %></textarea>

                    <!-- Submit -->

                    <button type="submit" class="w-full
                    py-4
                    rounded-xl
                    bg-gradient-to-r
                    from-pink-500
                    to-red-500
                    text-white
                    font-semibold
                    text-lg
                    shadow-xl
                    hover:scale-[1.02]
                    transition-all
                    duration-300">

                        <%= editing ? 'Update Home' : 'Add Home' %>

                    </button>

                </form>

            </div>

    </body>

    </html>