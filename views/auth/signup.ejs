<%- include('../partials/head') %>

<body class="bg-gray-900 min-h-screen flex flex-col">

    <%- include('../partials/nav') %>

    <!-- Form Container -->
    <div class="flex justify-center items-center flex-grow mt-8">
        <%- include('../partials/error-msg') %>
        <form action="/signup" method="post"
              class="rounded-xl p-8 w-full max-w-md space-y-6  bg-white/10
                    backdrop-blur-2xl
                    shadow-[0_20px_60px_rgba(0,0,0,0.45)]
                    border border-white/20">

            <h2 class="text-3xl font-bold text-blue-600 text-center">
                Sign Up
            </h2>

            <!-- Input Field -->
            <input 
                type="text" 
                name="firstname" 
                placeholder="First Name"
                value="<%= typeof oldInput !=='undefined'?oldInput.firstname : '' %>"
                class="w-full px-4 py-2  bg-white/10
                        border border-white/20
                        text-white
                        placeholder-gray-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400"
            >
            <input 
                type="text" 
                name="lastname" 
                placeholder="Last Name"
                value="<%= typeof oldInput !=='undefined' ? oldInput.lastname : '' %>"
                class="w-full px-4 py-2  bg-white/10
                        border border-white/20
                        text-white
                        placeholder-gray-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400"
            >
            <input 
                type="text" 
                name="email" 
                placeholder="Enter your Email"
                value="<%= typeof oldInput !=='undefined' ? oldInput.email : '' %>"
                class="w-full px-4 py-2  bg-white/10
                        border border-white/20
                        text-white
                        placeholder-gray-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400"
            >
            <input 
                type="password" 
                name="password" 
                placeholder="password"
                value="<%= typeof oldInput !=='undefined' ? oldInput.password : '' %>"
                class="w-full px-4 py-2  bg-white/10
                        border border-white/20
                        text-white
                        placeholder-gray-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400"
            >
            <input 
                type="password" 
                name="confirm_password" 
                placeholder="confirm password"
                class="w-full px-4 py-2  bg-white/10
                        border border-white/20
                        text-white
                        placeholder-gray-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400"
            >
            <span class="text-gray-400 font-medium">Usertype :- </span>

            <input type="radio" name="userType" value="guest"
            <%= typeof oldInput !=='undefined' && oldInput.userType==='guest' ? 'checked' : '' %>
            >
            <span class="text-gray-400 mr-2">Guest</span>

            <input type="radio" name="userType" value="host"
            <%= typeof oldInput !=='undefined' && oldInput.userType==='host' ? 'checked' : '' %>
            >
            <span class="text-gray-400">Host</span>
            
            <!-- Submit Button -->
            <input 
                type="submit" 
                value="Signup"
                class="w-full bg-red-500 text-white text-lg py-2 shadow-lg rounded-lg font-semibold hover:bg-red-600  hover:shadow-red-500/40
                         transition-all
                        duration-300 cursor-pointer"
            >

        </form>

    </div>

</body>
</html>